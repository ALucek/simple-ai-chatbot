# Local web dev (`pnpm dev`). The docker compose stack (`make stack-up`) reads NEXT_PUBLIC_* from the root .env instead.
NEXT_PUBLIC_API_URL=http://localhost:8080
# Google Sign-In client ID (same value as the API's GOOGLE_CLIENT_ID)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
# Optional: set "true" to emit the CSP as report-only (use during a rollout, then unset to enforce)
CSP_REPORT_ONLY=
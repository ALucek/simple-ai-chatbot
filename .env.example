DB_HOST=localhost
DB_PORT=5432
DB_USER=app
DB_PASSWORD=changeme
DB_NAME=chat
PORT=8080
ALLOWED_ORIGIN=http://localhost:3000
JWT_SECRET=changeme-generate-with-openssl-rand-hex-32
OPENROUTER_API_KEY=sk-or-your-key-here
OPENROUTER_MODEL=openrouter/free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1/chat/completions
SYSTEM_PROMPT=You are a helpful assistant.
# Optional DSN override
DATABASE_URL=
# Optional: log level — debug | info | warn | error (default info)
LOG_LEVEL=
# Optional: per-user rolling-24h token budget (default 8192; over → 429)
TOKEN_BUDGET_DAILY=
# Google Sign-In (the only login path)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
# OAuth client secret — the API exchanges the auth code for an id token with it
GOOGLE_CLIENT_SECRET=your-client-secret
# Same value as GOOGLE_CLIENT_ID; baked into the web image at build time — required for the docker compose stack (`make stack-up`)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
# Optional: this email gets an unlimited daily token budget
OWNER_EMAIL=
# Optional: set to "false" to block new account creation (existing users unaffected)
SIGNUP_OPEN=
# Optional: set "true" only behind a trusted proxy/LB so the real client IP is read from X-Forwarded-For
TRUST_PROXY=